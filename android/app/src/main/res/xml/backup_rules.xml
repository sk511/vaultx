<?xml version="1.0" encoding="utf-8"?>
<!--
  Backup Rules (Android < 12 / API < 31)
  Excludes all app data from Google Drive backup.
-->
<full-backup-content>
    <exclude domain="sharedpref" path="." />
    <exclude domain="database" path="." />
    <exclude domain="file" path="." />
</full-backup-content>
